# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_absensi_qr
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Application Settings
APP_DEBUG=false
APP_ENV=production
APP_TIMEZONE=Asia/Jakarta

# Security
ENABLE_HTTPS=false
SESSION_TIMEOUT=3600

# Attendance Settings
ATTENDANCE_DEADLINE_HOUR=08
ATTENDANCE_DEADLINE_MINUTE=00

# Logging
LOG_ERRORS=true
LOG_PATH=/var/log/tugasatippitra/
